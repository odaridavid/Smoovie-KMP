{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "docs",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/*.md",
      "**/*.gif"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/privacy-policy.html"
      },
      {
        "source": "/privacy",
        "destination": "/privacy-policy.html"
      },
      {
        "source": "/support",
        "destination": "/support.html"
      }
    ],
    "cleanUrls": true
  }
}
